# ──────────────────────────────────────────────────────────────────────────────
# API Keys — copy this file to .env and fill in your keys
# ──────────────────────────────────────────────────────────────────────────────
# The .env file is auto-loaded by agents/llm.py at import time.
# Real environment variables always take precedence over .env values.
#
# Available model presets (see agents/models.py or agent_config.json):
#   longcat   → LongCat-2.0-Preview
#   dashscope → kimi-k2.5 via Aliyun DashScope
# ──────────────────────────────────────────────────────────────────────────────

# Default API key for most presets (longcat, dashscope)
OPENAI_API_KEY=sk-your-key-here

# ── Add other keys if you use different presets ─────────────────────────────
# MY_OTHER_KEY=sk-...
